{
  "name": "huginn",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @huginn/web build",
    "build:agent": "pnpm --filter @huginn/agent build",
    "build:public-docs": "pnpm --filter @huginn/public-docs build",
    "build:private-docs": "pnpm --filter @huginn/private-docs build",
    "dev:public-docs": "pnpm --filter @huginn/public-docs dev",
    "dev:private-docs": "pnpm --filter @huginn/private-docs dev",
    "start:web": "node apps/web/.output/server/index.mjs",
    "start:agent": "pnpm --filter @huginn/agent start",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter @huginn/shared db:push",
    "db:generate": "pnpm --filter @huginn/shared db:generate",
    "db:studio": "pnpm --filter @huginn/shared db:studio"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7",
    "eslint": "^9",
    "@eslint/js": "^9",
    "typescript-eslint": "^8",
    "prettier": "^3"
  },
  "packageManager": "pnpm@10.6.5"
}
