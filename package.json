{
  "name": "huginn-second-brain",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @huginn/api dev",
    "dev:api": "pnpm --filter @huginn/api dev",
    "dev:public-docs": "pnpm --filter @huginn/public-docs dev",
    "dev:private-docs": "pnpm --filter @huginn/private-docs dev",
    "build": "pnpm --filter @huginn/api build",
    "build:api": "pnpm --filter @huginn/api build",
    "build:public-docs": "pnpm --filter @huginn/public-docs build",
    "build:private-docs": "pnpm --filter @huginn/private-docs build",
    "build:docs": "pnpm run build:public-docs && pnpm run build:private-docs",
    "start": "pnpm --filter @huginn/api start",
    "start:api": "pnpm --filter @huginn/api start",
    "start:public-docs": "pnpm --filter @huginn/public-docs serve",
    "start:private-docs": "pnpm --filter @huginn/private-docs serve",
    "telegram:webhook:set": "pnpm --filter @huginn/api telegram:webhook:set",
    "telegram:webhook:info": "pnpm --filter @huginn/api telegram:webhook:info"
  }
}