OPENROUTER_API_KEY=your-openrouter-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-public-domain/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret

# Daily Briefing — Telegram chat that receives the morning briefing (your personal chat ID).
# Find your chat ID by messaging @userinfobot on Telegram.
TELEGRAM_BRIEFING_CHAT_ID=your-telegram-chat-id

# Daily Briefing — Stable resource ID for the briefing user.
# Defaults to "tg-user-<TELEGRAM_BRIEFING_CHAT_ID>" if not set.
# BRIEFING_RESOURCE_ID=tg-user-123456789

# Daily Briefing — Timezone for displaying calendar event times in the briefing.
# Defaults to UTC. Use IANA timezone names e.g. "Europe/London", "America/New_York".
# BRIEFING_TIMEZONE=UTC

# Google Calendar OAuth2 credentials — required for calendar events in the daily briefing.
# 1. Create a project in Google Cloud Console and enable the Google Calendar API.
# 2. Create OAuth 2.0 credentials (Desktop or Web application).
# 3. Run the OAuth flow once to obtain a refresh token.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Optional: direct provider keys can still be used instead of the OpenRouter gateway.
# OPENAI_API_KEY=your-openai-api-key
