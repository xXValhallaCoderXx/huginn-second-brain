# Huginn Second Brain — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Routing (OpenRouter) ───────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Web Search (Tavily) ────────────────────────────────────────────
# Get your key at https://tavily.com
TAVILY_API_KEY=

# ─── Telegram Bot ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Gateway Auth ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
GATEWAY_TOKEN=

# ─── Deployment (optional) ──────────────────────────────────────────
# Your domain for HTTPS (used by Caddy proxy profile)
# DOMAIN=huginn.yourdomain.com

# ─── Syncthing (Vault Sync) ────────────────────────────────────────
# Credentials for the Syncthing web GUI (set on first run, change via GUI after)
# SYNCTHING_GUI_USER=admin
# SYNCTHING_GUI_PASSWORD=
