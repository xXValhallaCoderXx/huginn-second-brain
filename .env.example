# Huginn Second Brain — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Routing (OpenRouter) ───────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Web Search (Tavily) ────────────────────────────────────────────
# Get your key at https://tavily.com
TAVILY_API_KEY=

# ─── Telegram Bot ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── CouchDB (Phase 2 — LiveSync) ──────────────────────────────────
# COUCHDB_USER=admin
# COUCHDB_PASSWORD=
