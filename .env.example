# Huginn Second Brain — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Routing (OpenRouter) ───────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Storage (libSQL) ────────────────────────────────────────────────
# Connection URL for the libSQL database.
# Default: file:./mastra.db (local SQLite file)
# For hosted Turso: libsql://<your-db>.turso.io
LIBSQL_URL=

# ─── Telegram Bot ────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=

# Public webhook URL for the Telegram bot (used in production).
# Set this to your deployment URL with the /telegram/webhook path, e.g.:
#   https://<your-app>.up.railway.app/telegram/webhook
# Leave unset to skip automatic webhook registration (e.g. during local dev).
TELEGRAM_WEBHOOK_URL=
